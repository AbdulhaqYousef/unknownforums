<% content_for :title, "Login" %>
<% meta_description "Log in to #{forum_name} to join the discussion." %>
<% noindex_page %>

<div style="max-width:400px; margin:20px auto;">
  <div class="panel">
    <div class="panel-header">Sign in</div>
    <div style="padding:16px;">
      <p style="font-size:11px; color:var(--text-dim); line-height:1.5; margin-top:0;">
        If email 2FA is enabled on your profile, a login code will be sent after your password is accepted.
      </p>
      <%= form_with url: login_path, data: { turbo: false } do |f| %>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-size:11px; color:var(--text-dim); margin-bottom:3px;">Username:</label>
          <%= f.text_field :username, style: "width:100%;", autocomplete: "username" %>
        </div>
        <div style="margin-bottom:4px;">
          <label style="display:block; font-size:11px; color:var(--text-dim); margin-bottom:3px;">Password:</label>
          <%= f.password_field :password, style: "width:100%;", autocomplete: "current-password" %>
        </div>
        <div style="text-align:right; margin-bottom:12px;">
          <a href="<%= new_password_reset_path %>" style="font-size:10px; color:var(--text-muted);">Forgot password?</a>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <%= f.submit "Sign in", class: "btn btn-primary", style: "padding:4px 20px;" %>
          <a href="<%= register_path %>" style="font-size:11px; color:var(--text-dim);">No account? Register</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
