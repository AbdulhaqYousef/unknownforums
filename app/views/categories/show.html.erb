<% content_for :title, @category.name %>

<div style="font-size:11px; color:#888; margin-bottom:6px;">
  <a href="<%= root_path %>">Forum</a> &raquo;
  <strong style="color:#cfcfcf;"><%= @category.name %></strong>
</div>

<div style="background:#303030; border:1px solid #444; border-bottom:none; padding:6px 10px; font-size:13px; font-weight:bold; color:#e0e0e0;">
  <%= @category.name %>
</div>

<% if @category.description.present? %>
  <div style="background:#1e1e1e; border:1px solid #444; border-top:none; padding:8px 10px; font-size:11px; color:#888; margin-bottom:8px;">
    <%= @category.description %>
  </div>
<% end %>

<table style="border:1px solid #444; margin-bottom:8px; width:100%;">
  <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
    <th style="text-align:left; padding:3px 10px;">Subforum</th>
    <th style="text-align:center; padding:3px 10px;">Threads</th>
    <th style="text-align:center; padding:3px 10px;">Posts</th>
  </tr>
  <% if @subforums.empty? %>
    <tr><td colspan="3" style="padding:16px; text-align:center; color:#666;">No subforums in this category.</td></tr>
  <% end %>
  <% @subforums.each_with_index do |subforum, i| %>
    <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
      <td style="padding:7px 10px;">
        <a href="<%= subforum_path(subforum) %>" style="font-size:12px; font-weight:bold; color:#a8c8f0;"><%= subforum.name %></a>
        <% if subforum.description.present? %>
          <div style="font-size:10px; color:#666; margin-top:2px;"><%= subforum.description.truncate(120) %></div>
        <% end %>
      </td>
      <td style="text-align:center; font-size:12px; color:#cfcfcf;"><%= subforum.threads_count %></td>
      <td style="text-align:center; font-size:12px; color:#cfcfcf;"><%= subforum.posts_count %></td>
    </tr>
  <% end %>
</table>

<div style="font-size:11px; color:#888;">
  <a href="<%= root_path %>">← Back to forum home</a>
</div>
