<div style="border-top:1px solid var(--border-dim); margin-top:24px; background:#111;">
  <div style="max-width:1100px; margin:0 auto; padding:14px 10px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
    <div style="font-size:11px; color:var(--text-muted);">
      <span style="color:var(--accent); font-weight:bold;"><%= forum_name %></span>
      <span style="margin:0 6px; color:var(--border);">|</span>
      All times UTC
    </div>
    <div style="display:flex; gap:16px; font-size:11px;">
      <a href="<%= rules_path %>" style="color:var(--text-muted);">Rules</a>
      <a href="<%= terms_path %>" style="color:var(--text-muted);">Terms</a>
      <a href="<%= privacy_path %>" style="color:var(--text-muted);">Privacy</a>
    </div>
  </div>
</div>
