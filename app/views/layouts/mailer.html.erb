<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      body { background:#1b1b1b; color:#cfcfcf; font-family:Verdana, Arial, sans-serif; font-size:13px; line-height:1.6; margin:0; padding:24px; }
      .box { max-width:520px; margin:0 auto; background:#242424; border:1px solid #444; }
      .head { background:#303030; border-bottom:1px solid #444; color:#e0e0e0; font-weight:bold; padding:10px 14px; }
      .body { padding:16px; }
      .code { background:#111; border:1px solid #555; color:#f0c060; font-size:28px; font-weight:bold; letter-spacing:6px; padding:12px; text-align:center; }
      .muted { color:#888; font-size:11px; }
    </style>
  </head>
  <body>
    <div class="box">
      <div class="head">UnknownForums</div>
      <div class="body"><%= yield %></div>
    </div>
  </body>
</html>
