<% if @active_warnings&.any? %>
  <div style="background:#2a2218; border-bottom:1px solid #6a4a20; padding:8px 12px; font-size:11px; color:#f0d8a8;">
    <div style="max-width:1100px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap;">
      <span>
        <strong style="color:#f0c060;">Staff warning:</strong>
        <%= @active_warnings.first.reason.truncate(120) %>
        <% if @active_warnings.size > 1 %>
          <span style="color:#888;">(+<%= @active_warnings.size - 1 %> more)</span>
        <% end %>
      </span>
      <a href="<%= user_warnings_path %>" class="btn btn-sm" style="background:#4a3a18; border-color:#6a5a20; color:#f0d8a8;">View warnings</a>
    </div>
  </div>
<% end %>
