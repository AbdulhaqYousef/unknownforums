<% size ||= 48 %>
<% show_names ||= false %>
<% if badges.any? %>
  <div class="user-badges-display" style="display:flex; flex-wrap:wrap; gap:<%= show_names ? 10 : 8 %>px; justify-content:center; margin-bottom:<%= show_names ? 10 : 8 %>px;">
    <% badges.each do |badge| %>
      <div style="text-align:center; max-width:<%= size + 24 %>px;" title="<%= badge.description.presence || badge.name %>">
        <%= badge_image_tag badge, size: size, style: "border-radius:4px; border:1px solid #444; background:#1a1a1a; padding:2px;" %>
        <% if show_names %>
          <div style="font-size:10px; color:#aaa; margin-top:4px; line-height:1.2;"><%= badge.name %></div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
