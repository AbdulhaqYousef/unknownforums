<% size ||= 96 %>
<% show_names ||= false %>
<% featured ||= false %>
<% if badges.any? %>
  <div class="user-badges-display<%= " user-badges-display--featured" if featured %>" style="display:flex; flex-wrap:wrap; gap:<%= show_names ? 12 : 10 %>px; justify-content:center; margin-bottom:<%= show_names ? 12 : 10 %>px; width:100%;">
    <% badges.each do |badge| %>
      <div class="user-badge-item" style="text-align:center; width:<%= featured ? "100%" : "auto" %>;" title="<%= badge.description.presence || badge.name %>">
        <%= badge_image_tag badge, size: size, style: "border-radius:6px; border:2px solid #555; background:#111; padding:4px; box-sizing:border-box;" %>
        <% if show_names %>
          <div style="font-size:12px; color:#ccc; margin-top:6px; line-height:1.3; font-weight:bold;"><%= badge.name %></div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
