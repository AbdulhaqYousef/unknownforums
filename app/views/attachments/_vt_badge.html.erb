<% return unless attachment.vt_badge_visible? %>

<% color = case attachment.vt_status
  when "clean" then "#80c080"
  when "malicious" then "#f08080"
  when "suspicious" then "#f0c060"
  when "pending", "scanning" then "#7aabde"
  else "#999"
end %>
<% bg = case attachment.vt_status
  when "clean" then "#1a3a1a"
  when "malicious" then "#4a1a1a"
  when "suspicious" then "#4a3a00"
  when "pending", "scanning" then "#1a2a3a"
  else "#2a2a2a"
end %>
<span style="display:inline-flex; align-items:center; gap:4px; padding:1px 6px; border:1px solid <%= color %>; background:<%= bg %>; color:<%= color %>; font-size:9px; font-weight:bold; text-transform:uppercase; white-space:nowrap;">
  <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:<%= color %>;"></span>
  <%= attachment.vt_status_label %>
</span>
