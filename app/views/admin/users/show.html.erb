<% content_for :title, @user.username %>

<div style="font-size:11px; color:#888; margin-bottom:6px;">
  <a href="<%= admin_users_path %>">← Users</a>
</div>

<div style="background:#242424; border:1px solid #444; padding:12px; max-width:500px;">
  <table style="font-size:12px; width:100%;">
    <tr><td style="padding:4px 0; color:#888; width:120px;">Username:</td><td><strong><%= @user.username %></strong></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Email:</td><td><%= @user.email || "—" %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Role:</td><td><%= @user.role %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Reputation:</td><td><%= @user.reputation %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Posts:</td><td><%= @user.post_count %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Old Names:</td><td><%= @user.previous_usernames.any? ? @user.previous_usernames.join(", ") : "—" %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Status:</td><td><%= [(@user.banned? ? "Banned" : nil), (@user.flagged? ? "Flagged" : nil)].compact.presence&.join(", ") || "Active" %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Flag reason:</td><td><%= @user.flag_reason.presence || "—" %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Mod note:</td><td><%= @user.moderation_note.presence || "—" %></td></tr>
    <tr><td style="padding:4px 0; color:#888;">Joined:</td><td><%= @user.created_at.strftime("%m/%d/%Y") %></td></tr>
  </table>
  <div class="action-group" style="margin-top:10px;">
    <a href="<%= edit_admin_user_path(@user) %>" class="btn btn-primary btn-sm">Edit</a>
    <a href="<%= user_path(@user) %>" class="btn btn-sm">View Profile</a>
    <% if @user.banned? %>
      <%= button_to "Unban", unban_admin_user_path(@user), method: :patch, class: "btn btn-success btn-sm" %>
    <% else %>
      <%= button_to "Ban", ban_admin_user_path(@user), method: :patch, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Ban #{@user.username}?" } %>
    <% end %>
    <% if @user.flagged? %>
      <%= button_to "Unflag", unflag_admin_user_path(@user), method: :patch, class: "btn btn-sm" %>
    <% else %>
      <%= button_to "Flag", flag_admin_user_path(@user, flag_reason: "Needs admin review"), method: :patch, class: "btn btn-sm" %>
    <% end %>
  </div>
</div>
