<% content_for :title, "Reports" %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
  <span style="font-size:13px; font-weight:bold; color:#e0e0e0;">Reports</span>
  <div style="display:flex; gap:4px;">
    <%= link_to "All", admin_reports_path, class: "btn btn-sm #{params[:status].blank? ? 'btn-primary' : ''}" %>
    <%= link_to "Pending", admin_reports_path(status: :pending), class: "btn btn-sm #{params[:status] == 'pending' ? 'btn-primary' : ''}" %>
    <%= link_to "Resolved", admin_reports_path(status: :resolved), class: "btn btn-sm #{params[:status] == 'resolved' ? 'btn-primary' : ''}" %>
  </div>
</div>

<div class="panel" style="margin-bottom:10px;">
  <div class="panel-body">
    <%= form_with url: admin_reports_path, method: :get, class: "admin-search-form" do |f| %>
      <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
      <div class="admin-search-field grow">
        <label>Search Reports</label>
        <%= f.text_field :q, value: params[:q], placeholder: "Reason, type, reporter username/email...", style: "width:100%;" %>
      </div>
      <div class="admin-search-actions">
        <%= f.submit "Search", class: "btn btn-primary" %>
        <a href="<%= admin_reports_path(status: params[:status].presence) %>" class="btn">Reset</a>
      </div>
    <% end %>
  </div>
</div>

<div style="background:#242424; border:1px solid #444;">
  <table>
    <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
      <th style="padding:3px 10px; text-align:left;">Type</th>
      <th style="padding:3px 10px; text-align:left;">Reporter</th>
      <th style="padding:3px 10px; text-align:left;">Reason</th>
      <th style="padding:3px 10px; text-align:center;">Status</th>
      <th style="padding:3px 10px; text-align:center;">Date</th>
      <th style="padding:3px 10px; text-align:center;">Actions</th>
    </tr>
    <% if @reports.empty? %>
      <tr><td colspan="6" style="padding:20px; text-align:center; color:#666; font-size:12px;">No reports.</td></tr>
    <% end %>
    <% @reports.each_with_index do |report, i| %>
      <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
        <td style="padding:5px 10px; font-size:11px;"><%= report.reportable_type %></td>
        <td style="padding:5px 10px; font-size:11px;">
          <a href="<%= user_path(report.reporter) %>"><%= report.reporter.username %></a>
        </td>
        <td style="padding:5px 10px; font-size:11px; color:#888;">
          <%= truncate(report.reason, length: 60) %>
          <% if report.screenshots.attached? %>
            <span style="color:#7aabde; margin-left:4px;" title="<%= report.screenshots.count %> screenshot(s)">&#128247; <%= report.screenshots.count %></span>
          <% end %>
        </td>
        <td style="padding:5px 10px; text-align:center; font-size:11px;">
          <span style="color:<%= report.pending? ? '#f0a060' : '#80c080' %>"><%= report.status %></span>
        </td>
        <td style="padding:5px 10px; text-align:center; font-size:10px; color:#666;"><%= report.created_at.strftime("%m/%d/%y") %></td>
        <td style="padding:5px 10px; text-align:center;">
          <a href="<%= admin_report_path(report) %>" class="btn btn-sm">View</a>
        </td>
      </tr>
    <% end %>
  </table>
</div>

<div style="margin-top:6px; font-size:11px; color:#888; display:flex; justify-content:space-between; align-items:center;">
  <span>Page <%= @reports.current_page %> of <%= @reports.total_pages %></span>
  <div>
    <%= link_to_prev_page @reports, "← Prev", class: "btn btn-sm" %>
    <%= link_to_next_page @reports, "Next →", class: "btn btn-sm" %>
  </div>
</div>
