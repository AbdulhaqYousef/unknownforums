<% if badge.errors.any? %>
  <div style="background:#3a1a1a; border:1px solid #6a2a2a; padding:8px 10px; margin-bottom:12px;">
    <ul class="error-list">
      <% badge.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: badge, url: badge.persisted? ? admin_badge_path(badge) : admin_badges_path, method: badge.persisted? ? :patch : :post, multipart: true do |f| %>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Name:</label>
    <%= f.text_field :name, style: "width:100%;" %>
  </div>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Description:</label>
    <%= f.text_area :description, rows: 3, style: "width:100%; resize:vertical;" %>
  </div>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Sort position:</label>
    <%= f.number_field :position, style: "width:100px;" %>
  </div>
  <div style="margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid #333;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:6px;">Badge image (GIF recommended):</label>
    <% if badge.image.attached? %>
      <div style="margin-bottom:8px;"><%= badge_image_tag badge, size: 48 %></div>
      <label style="display:flex; align-items:center; gap:4px; margin-bottom:8px; font-size:11px; color:#c08080; cursor:pointer;">
        <input type="checkbox" name="badge[remove_image]" value="1" style="width:12px; height:12px;">
        Remove current image
      </label>
    <% end %>
    <%= f.file_field :image, accept: "image/gif,image/png,image/jpeg,image/webp", style: "font-size:11px; color:#888;" %>
    <div style="font-size:10px; color:#666; margin-top:3px;">GIF, PNG, JPEG or WebP — max 10MB</div>
  </div>
  <div style="display:flex; gap:8px;">
    <%= f.submit badge.persisted? ? "Save Badge" : "Create Badge", class: "btn btn-primary" %>
    <a href="<%= admin_badges_path %>" class="btn">Cancel</a>
  </div>
<% end %>
