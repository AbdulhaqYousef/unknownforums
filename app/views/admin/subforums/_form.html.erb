<% action = subforum.new_record? ? admin_subforums_path : admin_subforum_path(subforum) %>
<% method = subforum.new_record? ? :post : :patch %>

<% if subforum.errors.any? %>
  <div style="background:#3a1a1a; border:1px solid #6a2a2a; padding:8px; margin-bottom:10px;">
    <ul class="error-list">
      <% subforum.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: subforum, url: action, method: method, data: { turbo: false } do |f| %>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Name:</label>
    <%= f.text_field :name, style: "width:100%;" %>
  </div>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Description:</label>
    <%= f.text_area :description, rows: 3, style: "width:100%; resize:vertical;" %>
  </div>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Category:</label>
    <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, subforum.category_id),
      {}, style: "width:100%;" %>
  </div>
  <div style="margin-bottom:12px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Position:</label>
    <%= f.number_field :position, style: "width:80px;", min: 0 %>
  </div>
  <div style="margin-bottom:12px;">
    <label style="display:flex; align-items:center; gap:8px; font-size:11px; color:#cfcfcf; cursor:pointer;">
      <%= f.check_box :public_read %>
      Allow guests to read this subforum without signing in
    </label>
    <div style="font-size:10px; color:#666; margin-top:4px;">When unchecked, guests see the subforum listed but must sign in to open threads or download files from it.</div>
  </div>
  <%= render "admin/shared/file_type_restrictions",
        inherit: true,
        inherit_checked: subforum.file_types_inherited?,
        inherit_label: "Use category default file types",
        selected_groups: subforum.selected_file_type_groups,
        custom_upload_types: subforum.custom_upload_types_text,
        field_prefix: "subforum-" %>
  <%= render "admin/shared/upload_size_limit",
        inherit: true,
        inherit_checked: subforum.upload_limit_inherited?,
        inherit_label: "Use category default upload limit",
        upload_max_gb: subforum.upload_limit_gb_input,
        effective_label: subforum.effective_upload_limit_label,
        field_prefix: "subforum-" %>
  <div style="display:flex; gap:8px;">
    <%= f.submit subforum.new_record? ? "Create" : "Save", class: "btn btn-primary" %>
    <a href="<%= admin_subforums_path %>" class="btn">Cancel</a>
  </div>
<% end %>
