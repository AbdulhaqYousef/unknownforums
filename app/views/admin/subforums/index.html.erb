<% content_for :title, "Manage Subforums" %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
  <span style="font-size:13px; font-weight:bold; color:#e0e0e0;">Subforums</span>
  <div class="action-group">
    <a href="<%= admin_site_settings_path %>" class="btn btn-sm">Site Upload Types</a>
    <a href="<%= new_admin_subforum_path %>" class="btn btn-primary">+ New Subforum</a>
  </div>
</div>

<div style="background:#1a242a; border:1px solid #2a3a44; padding:8px 10px; margin-bottom:10px; font-size:11px; color:#9ab;">
  Per-subforum upload rules are on each subforum's <strong>Edit</strong> page. Site-wide default:
  <strong style="color:#c8d8e8;"><%= AllowedFileTypes.global_policy_label %></strong>
</div>

<div class="panel" style="margin-bottom:10px;">
  <div class="panel-body">
    <%= form_with url: admin_subforums_path, method: :get, class: "admin-search-form" do |f| %>
      <div class="admin-search-field grow">
        <label>Search Subforums</label>
        <%= f.text_field :q, value: params[:q], placeholder: "Name, description, or category...", style: "width:100%;" %>
      </div>
      <div class="admin-search-actions">
        <%= f.submit "Search", class: "btn btn-primary" %>
        <a href="<%= admin_subforums_path %>" class="btn">Reset</a>
      </div>
    <% end %>
  </div>
</div>

<div style="background:#242424; border:1px solid #444;">
  <table>
    <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
      <th style="padding:3px 10px; text-align:left;">Name</th>
      <th style="padding:3px 10px; text-align:left;">Category</th>
      <th style="padding:3px 10px; text-align:center;">Position</th>
      <th style="padding:3px 10px; text-align:center;">Threads</th>
      <th style="padding:3px 10px; text-align:left;">Upload Types</th>
      <th style="padding:3px 10px; text-align:center;">Actions</th>
    </tr>
    <% if @subforums.empty? %>
      <tr><td colspan="6" style="padding:20px; text-align:center; color:#666; font-size:12px;">No subforums matched your search.</td></tr>
    <% end %>
    <% @subforums.each_with_index do |sf, i| %>
      <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
        <td style="padding:5px 10px; font-size:12px;"><%= sf.name %></td>
        <td style="padding:5px 10px; font-size:11px; color:#888;"><%= sf.category.name %></td>
        <td style="padding:5px 10px; text-align:center; font-size:12px;"><%= sf.position %></td>
        <td style="padding:5px 10px; text-align:center; font-size:12px;"><%= sf.threads_count %></td>
        <td style="padding:5px 10px; font-size:10px; color:#888;"><%= AllowedFileTypes.admin_policy_label(sf) %></td>
        <td style="padding:5px 10px; text-align:center;">
          <div class="action-group" style="justify-content:center;">
            <a href="<%= admin_subforum_threads_path(sf) %>" class="btn btn-sm">Threads</a>
            <a href="<%= edit_admin_subforum_path(sf) %>" class="btn btn-sm">Edit</a>
            <%= button_to "Delete", admin_subforum_path(sf), method: :delete, class: "btn btn-danger btn-sm",
              data: { turbo_confirm: "Delete subforum and all threads?" } %>
          </div>
        </td>
      </tr>
    <% end %>
  </table>
</div>
