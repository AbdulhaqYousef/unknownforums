<% inherit = local_assigns.fetch(:inherit, false) %>
<% inherit_checked = local_assigns.fetch(:inherit_checked, false) %>
<% inherit_label = local_assigns.fetch(:inherit_label, "Inherit from parent") %>
<% selected = local_assigns.fetch(:selected_groups, AllowedFileTypes.group_keys) %>
<% field_prefix = local_assigns.fetch(:field_prefix, "") %>

<div style="background:#1e1e1e; border:1px solid #333; padding:10px; margin-bottom:12px;">
  <div style="font-size:10px; color:#888; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Allowed Upload Types</div>

  <% if inherit %>
    <label style="display:flex; align-items:flex-start; gap:8px; font-size:11px; color:#cfcfcf; cursor:pointer; margin-bottom:10px;">
      <input type="checkbox" name="file_type_inherit" value="1" <%= inherit_checked ? "checked" : "" %>
        id="<%= field_prefix %>file-type-inherit" style="width:14px; height:14px; margin-top:1px;">
      <span>
        <strong><%= inherit_label %></strong>
        <span style="display:block; color:#666; font-size:10px; margin-top:2px;">When checked, this forum uses the parent setting instead of its own list.</span>
      </span>
    </label>
  <% else %>
    <div style="font-size:10px; color:#666; margin-bottom:8px;">Leave all checked to allow every supported file type site-wide. Uncheck groups to block them everywhere unless a category or subforum overrides.</div>
  <% end %>

  <div id="<%= field_prefix %>file-type-groups" style="<%= inherit && inherit_checked ? "opacity:0.45; pointer-events:none;" : "" %>">
    <% AllowedFileTypes::GROUPS.each do |key, meta| %>
      <label style="display:flex; align-items:flex-start; gap:8px; font-size:11px; color:#bbb; cursor:pointer; margin-bottom:6px;">
        <input type="checkbox" name="file_type_groups[]" value="<%= key %>"
          <%= selected.include?(key) ? "checked" : "" %>
          class="file-type-group-checkbox" style="width:14px; height:14px; margin-top:1px;">
        <span><%= meta[:label] %></span>
      </label>
    <% end %>
  </div>
</div>

<% if inherit %>
  <script>
    (function() {
      const inheritBox = document.getElementById("<%= field_prefix %>file-type-inherit")
      const groupsBox = document.getElementById("<%= field_prefix %>file-type-groups")
      if (!inheritBox || !groupsBox) return
      inheritBox.addEventListener("change", function() {
        groupsBox.style.opacity = this.checked ? "0.45" : ""
        groupsBox.style.pointerEvents = this.checked ? "none" : ""
      })
    })()
  </script>
<% end %>
