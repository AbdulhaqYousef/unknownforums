<% content_for :title, "Attack Events" %>

<% if @spike %>
  <div style="background:#4a1a1a; border:1px solid #8a2a2a; padding:10px 14px; margin-bottom:12px; font-size:12px; color:#f08080;">
    &#9888; <strong>Attack spike detected</strong> — 20+ throttle events in the last 5 minutes. Review the top IPs below.
  </div>
<% end %>

<div class="panel">
  <div class="panel-header" style="display:flex; justify-content:space-between; align-items:center;">
    <span>Attack Events</span>
    <span style="font-size:11px; color:#888;">Today: <%= @total_today %> events</span>
  </div>
  <div class="panel-body" style="padding:0; display:flex; gap:0; flex-wrap:wrap;">

    <!-- Top IPs this hour -->
    <div style="flex:0 0 220px; border-right:1px solid #333; padding:10px;">
      <div style="font-size:10px; color:#888; text-transform:uppercase; margin-bottom:6px;">Top IPs (last hour)</div>
      <% if @top_ips.any? %>
        <% @top_ips.each do |ip, count| %>
          <div style="font-size:11px; margin-bottom:4px; display:flex; justify-content:space-between;">
            <span style="font-family:monospace; color:#cfcfcf;"><%= ip %></span>
            <span style="color:#f0c060;"><%= count %></span>
          </div>
          <div style="margin-bottom:4px;">
            <a href="https://www.abuseipdb.com/check/<%= ip %>" target="_blank" style="font-size:10px; color:#7aabde;">lookup</a>
          </div>
        <% end %>
      <% else %>
        <span style="color:#555; font-size:11px;">No events this hour.</span>
      <% end %>
    </div>

    <!-- Event log -->
    <div style="flex:1; min-width:0;">
      <table style="font-size:11px;">
        <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
          <th style="text-align:left;">Time</th>
          <th style="text-align:left;">IP</th>
          <th style="text-align:left;">Rule</th>
          <th style="text-align:left;">Path</th>
        </tr>
        <% @events.each do |e| %>
          <tr>
            <td style="color:#888; white-space:nowrap;"><%= e.occurred_at.strftime("%m/%d %H:%M:%S") %></td>
            <td style="font-family:monospace; color:#cfcfcf;"><%= e.ip_address %></td>
            <td style="color:#f0c060;"><%= e.matched %></td>
            <td style="color:#888; max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= e.path %></td>
          </tr>
        <% end %>
      </table>
      <% if @events.empty? %>
        <div style="padding:20px; color:#555; text-align:center; font-size:12px;">No attack events recorded.</div>
      <% end %>
    </div>

  </div>
</div>
