<% content_for :title, "Manage Categories" %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
  <span style="font-size:13px; font-weight:bold; color:#e0e0e0;">Categories</span>
  <div class="action-group">
    <a href="<%= admin_site_settings_path %>" class="btn btn-sm">Site Upload Types</a>
    <a href="<%= new_admin_category_path %>" class="btn btn-primary">+ New Category</a>
  </div>
</div>

<div style="background:#1a242a; border:1px solid #2a3a44; padding:8px 10px; margin-bottom:10px; font-size:11px; color:#9ab;">
  Upload file types are <strong>not</strong> edited on this list. Click <strong>Edit</strong> on a category for per-category rules, or use
  <a href="<%= admin_site_settings_path %>" style="color:#7aabde;">Site Settings</a> for the global default.
  Site-wide: <strong style="color:#c8d8e8;"><%= AllowedFileTypes.global_policy_label %></strong>
  &middot; max <strong style="color:#c8d8e8;"><%= UploadLimits.global_label %></strong>
</div>

<div class="panel" style="margin-bottom:10px;">
  <div class="panel-body">
    <%= form_with url: admin_categories_path, method: :get, class: "admin-search-form" do |f| %>
      <div class="admin-search-field grow">
        <label>Search Categories</label>
        <%= f.text_field :q, value: params[:q], placeholder: "Name or description...", style: "width:100%;" %>
      </div>
      <div class="admin-search-actions">
        <%= f.submit "Search", class: "btn btn-primary" %>
        <a href="<%= admin_categories_path %>" class="btn">Reset</a>
      </div>
    <% end %>
  </div>
</div>

<div style="background:#242424; border:1px solid #444;">
  <table>
    <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
      <th style="padding:3px 10px; text-align:left;">Name</th>
      <th style="padding:3px 10px; text-align:center;">Position</th>
      <th style="padding:3px 10px; text-align:center;">Subforums</th>
      <th style="padding:3px 10px; text-align:left;">Upload Types</th>
      <th style="padding:3px 10px; text-align:left;">Upload Limit</th>
      <th style="padding:3px 10px; text-align:center;">Actions</th>
    </tr>
    <% if @categories.empty? %>
      <tr><td colspan="6" style="padding:20px; text-align:center; color:#666; font-size:12px;">No categories matched your search.</td></tr>
    <% end %>
    <% @categories.each_with_index do |cat, i| %>
      <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
        <td style="padding:5px 10px; font-size:12px;"><%= cat.name %></td>
        <td style="padding:5px 10px; text-align:center; font-size:12px;"><%= cat.position %></td>
        <td style="padding:5px 10px; text-align:center; font-size:12px;"><%= cat.subforums.count %></td>
        <td style="padding:5px 10px; font-size:10px; color:#888;"><%= AllowedFileTypes.admin_policy_label(cat) %></td>
        <td style="padding:5px 10px; font-size:10px; color:#888;"><%= UploadLimits.admin_label(cat) %></td>
        <td style="padding:5px 10px; text-align:center;">
          <div class="action-group" style="justify-content:center;">
            <a href="<%= admin_category_category_moderators_path(cat) %>" class="btn btn-sm">Staff</a>
            <a href="<%= edit_admin_category_path(cat) %>" class="btn btn-sm">Edit</a>
            <%= button_to "Delete", admin_category_path(cat), method: :delete, class: "btn btn-danger btn-sm",
              data: { turbo_confirm: "Delete category and all its subforums?" } %>
          </div>
        </td>
      </tr>
    <% end %>
  </table>
</div>
