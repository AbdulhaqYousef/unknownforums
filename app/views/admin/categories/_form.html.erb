<% action = category.new_record? ? admin_categories_path : admin_category_path(category) %>
<% method = category.new_record? ? :post : :patch %>

<% if category.errors.any? %>
  <div style="background:#3a1a1a; border:1px solid #6a2a2a; padding:8px; margin-bottom:10px;">
    <ul class="error-list">
      <% category.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: category, url: action, method: method do |f| %>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Name:</label>
    <%= f.text_field :name, style: "width:100%;" %>
  </div>
  <div style="margin-bottom:10px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Description:</label>
    <%= f.text_area :description, rows: 3, style: "width:100%; resize:vertical;" %>
  </div>
  <div style="margin-bottom:12px;">
    <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Position (lower = first):</label>
    <%= f.number_field :position, style: "width:80px;", min: 0 %>
  </div>
  <%= render "admin/shared/file_type_restrictions",
        inherit: true,
        inherit_checked: category.file_types_inherited?,
        inherit_label: "Use site default file types",
        selected_groups: category.file_types_inherited? ? SiteSetting.selected_file_type_groups : category.selected_file_type_groups,
        custom_upload_types: category.file_types_inherited? ? SiteSetting.custom_upload_types_text : category.custom_upload_types_text,
        field_prefix: "category-" %>
  <div style="display:flex; gap:8px;">
    <%= f.submit category.new_record? ? "Create" : "Save", class: "btn btn-primary" %>
    <a href="<%= admin_categories_path %>" class="btn">Cancel</a>
  </div>
<% end %>
