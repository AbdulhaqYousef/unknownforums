<% content_for :title, "Forgot Password" %>

<div class="panel" style="max-width:420px; margin:40px auto;">
  <div class="panel-header">Forgot your password?</div>
  <div style="padding:16px;">
    <p style="font-size:12px; color:var(--text-dim); margin-bottom:14px;">
      Enter your email address and we'll send you a link to reset your password.
    </p>
    <%= form_with url: password_resets_path, method: :post do |f| %>
      <div class="form-row">
        <%= f.label :email, "Email address", style: "font-size:11px; color:var(--text-dim);" %>
        <%= f.email_field :email, required: true, autofocus: true,
              style: "width:100%;", placeholder: "you@example.com" %>
      </div>
      <div style="margin-top:12px;">
        <%= f.submit "Send reset link", class: "btn btn-primary" %>
        &nbsp;
        <a href="<%= login_path %>" style="font-size:11px; color:var(--text-muted);">Back to sign in</a>
      </div>
    <% end %>
  </div>
</div>
