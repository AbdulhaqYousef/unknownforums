<% content_for :title, "Edit Thread" %>

<div style="background:#242424; border:1px solid #444;">
  <div style="background:#303030; border-bottom:1px solid #444; padding:6px 10px; font-size:13px; font-weight:bold; color:#e0e0e0;">
    Edit Thread Title
  </div>
  <div style="padding:12px;">
    <%= form_with model: @thread, url: forum_thread_path(@thread), method: :patch do |f| %>
      <div style="margin-bottom:10px;">
        <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Thread Title:</label>
        <%= f.text_field :title, style: "width:100%; max-width:600px;" %>
      </div>
      <div style="display:flex; gap:8px;">
        <%= f.submit "Save", class: "btn btn-primary" %>
        <a href="<%= forum_thread_path(@thread) %>" class="btn">Cancel</a>
      </div>
    <% end %>
  </div>
</div>
