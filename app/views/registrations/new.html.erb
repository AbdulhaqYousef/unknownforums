<% content_for :title, "Register" %>
<% meta_description "Create an account on #{forum_name} to join the community." %>
<% noindex_page %>

<div style="max-width:440px; margin:20px auto;">
  <div style="background:#242424; border:1px solid #444;">
    <div style="background:#303030; border-bottom:1px solid #444; padding:6px 10px; font-size:13px; font-weight:bold; color:#e0e0e0;">
      Create Account
    </div>
    <div style="padding:16px;">
      <% if @user.errors.any? %>
        <div style="background:#3a1a1a; border:1px solid #6a2a2a; padding:8px 10px; margin-bottom:12px;">
          <div style="color:#f08080; font-size:11px; font-weight:bold; margin-bottom:4px;">Please fix the following errors:</div>
          <ul class="error-list">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: register_path, data: { turbo: false } do |f| %>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Username: <span style="color:#f08080;">*</span></label>
          <%= f.text_field :username, style: "width:100%;", autocomplete: "username" %>
          <div style="font-size:10px; color:#666; margin-top:2px;">3–30 chars. Letters, numbers, underscores, dashes only.</div>
          <% if @user.errors[:username].any? %>
            <ul class="error-list"><% @user.errors[:username].each do |err| %><li><%= err %></li><% end %></ul>
          <% end %>
        </div>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Email: <span style="color:#f08080;">*</span></label>
          <%= f.email_field :email, style: "width:100%;", autocomplete: "email" %>
          <div style="font-size:10px; color:#666; margin-top:2px;">A verification code will be sent to this address.</div>
          <% if @user.errors[:email].any? %>
            <ul class="error-list"><% @user.errors[:email].each do |err| %><li><%= err %></li><% end %></ul>
          <% end %>
        </div>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Password: <span style="color:#f08080;">*</span></label>
          <%= f.password_field :password, style: "width:100%;", autocomplete: "new-password" %>
          <div style="font-size:10px; color:#666; margin-top:2px;">At least 8 characters, with lowercase, uppercase, and a number.</div>
          <% if @user.errors.any? %>
            <div style="font-size:10px; color:#888; margin-top:2px;">Passwords are cleared after failed signup attempts. Please re-enter them.</div>
          <% end %>
          <% if @user.errors[:password].any? %>
            <ul class="error-list"><% @user.errors[:password].each do |err| %><li><%= err %></li><% end %></ul>
          <% end %>
        </div>
        <div style="margin-bottom:14px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Confirm Password: <span style="color:#f08080;">*</span></label>
          <%= f.password_field :password_confirmation, style: "width:100%;", autocomplete: "new-password" %>
          <% if @user.errors[:password_confirmation].any? %>
            <ul class="error-list"><% @user.errors[:password_confirmation].each do |err| %><li><%= err %></li><% end %></ul>
          <% end %>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <%= f.submit "Register", class: "btn btn-primary", style: "padding:4px 20px;" %>
          <a href="<%= login_path %>" style="font-size:11px; color:#888;">Already have an account? Login</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
